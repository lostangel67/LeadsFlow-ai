{
  "name": "leadsflow",
  "version": "2.0.0",
  "description": "LeadsFlow — Prospecção automatizada com interface gráfica",
  "main": "electron/main.js",
  "scripts": {
    "electron": "electron .",
    "build": "electron-builder --win",
    "start-cli": "node index.js"
  },
  "build": {
    "appId": "com.leadsflow.app",
    "productName": "LeadsFlow",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "src/**/*",
      "config.js",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "artifactName": "LeadsFlow-Setup-${version}.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "lostangel67",
      "repo": "LeadsFlow-ai"
    }
  },
  "keywords": [
    "whatsapp",
    "automation",
    "google-maps",
    "prospecting",
    "electron"
  ],
  "author": "LeadsFlow",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "dotenv": "^16.4.7",
    "electron-updater": "^6.8.3",
    "openai": "^6.37.0"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "puppeteer": "^24.0.0"
  }
}
